# Algorand node URLs (Nodely mainnet by default, change to testnet for development)
NEXT_PUBLIC_ALGOD_URL=https://mainnet-api.4160.nodely.dev
NEXT_PUBLIC_INDEXER_URL=https://mainnet-idx.4160.nodely.dev

# Creator address for your NFT collection (used to validate assets belong
# to your collection during ARC-19 updates). Leave blank to skip creator validation.
COLLECTION_CREATOR_ADDRESS=

# Manager wallet mnemonic (25 words) — used for ARC-19 metadata updates
# This wallet must be the manager address of your NFT collection
MANAGER_MNEMONIC=

# Pinata JWT for IPFS uploads (get one at https://app.pinata.cloud)
PINATA_JWT=

# Set to "true" when ready for live on-chain trait updates
# Leave "false" during development — mint runs in preview-only mode
ARC19_LIVE_UPDATES_ENABLED=false

# Treasury wallet address — receives trait swap fees (required)
TREASURY_ADDRESS=

# --- Loot Box System ---
# Mnemonic for the prize distribution wallet (must hold prize tokens/NFTs)
LOOTBOX_MASTER_MNEMONIC=

# App ID of the deployed LootBox smart contract (commit-reveal)
LOOTBOX_CONTRACT_APP_ID=

# Set to "true" to enable live prize distribution
LOOTBOX_LIVE_ENABLED=false

# Set to "true" to temporarily pause loot box reveals
# LOOTBOX_PAUSED=false

# Loot box price in ALGO (defaults to 10 if not set)
# LOOTBOX_PRICE_ALGO=10

# Admin wallet addresses (comma-separated) — wallets that can access admin panel
ADMIN_WALLETS=

# --- Optional: Vercel Blob for persistent prize config ---
# BLOB_READ_WRITE_TOKEN=
# Direct URL to the Blob-stored prizes JSON (used by the prize store)
# LOOTBOX_PRIZES_BLOB_URL=
